%%
%% Included are a set of commands to generate comments for a LaTeX file.
%%
%% This package requires the following standard packages: 
%%     ulem: for \sout
%%     xcolor: for coloring text.
%%     pdfcomment: if pdfcomment option is used


\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{ezedits}[2019/12/17, edited by MF 2021/05/18]

%\RequirePackage[normalem]{ulem}
%\RequirePackage{color}

\newif\if@accept\@acceptfalse % accept all comments (does not suppress package warnings)
\newif\if@reject\@rejectfalse % reject all comments (does not suppress package warnings)
\newif\if@pdfcomm\@pdfcommfalse % write pdf comments
\newif\if@showarrows\@showarrowsfalse

\DeclareOption{accept}{
    \@accepttrue
}
\DeclareOption{reject}{
    \@rejecttrue
}
\DeclareOption{pdfcomment}{ % add pdf comments
    \@pdfcommtrue
    \AtEndOfPackage{\RequirePackage{pdfcomment}}
}
\DeclareOption{arrows}{ % point to edits with arrows in the margin
    \@showarrowstrue
    \AtEndOfPackage{\RequirePackage{marginnote}}
}

\ProcessOptions\relax


% note that the \draftNote is in red.
\newcommand{\draftNote}[1]{\PackageWarning{ezedits}{Unresolved note: #1}%
    \if@showarrows%
        \@ifundefined{@captype}%
            {\marginnote{\textcolor{red}{\Large$\bm{\Longleftarrow}$}}}%
            {\textcolor{red}{\Large$\bm{\Longrightarrow}$}}%
    \fi%
    \if@accept{}\else
        \if@pdfcomm%
            \pdfmargincomment{#1}%
        \else%
            \textcolor{red}{\textbf{[#1]}}%
        \fi\fi%
    \if@showarrows% if in caption, draw end arrow
        \@ifundefined{@captype}{}{\textcolor{red}{\Large$\bm{\Longleftarrow}$}}\fi%
}

% A quick shortcut for the longer defineEdit command: just supply this <INITIALS> and a color name
\newcommand{\defineEditQuick}[2]{\defineEdit{#1}{\textcolor{#2}}{\textcolor{#2}}}


\newcommand{\defineEdit}[3]{%
    % "\###Edit" for removing and adding text
    \expandafter\newcommand\csname #1Edit\endcsname[2]{\PackageWarning{ezedits}{Unresolved modifications by #1: "##1" ---> "##2"}%
        \if@showarrows%
            \@ifundefined{@captype}%
                {\marginnote{{#3{\Large$\bm{\Longleftarrow}$}}}}%
                {{#3{\Large$\bm{\Longrightarrow}$}}}%
        \fi%
        \if@accept% Display as if accepted
            { }##2%
        \else%
            \if@pdfcomm%
                \pdfmarkupcomment[author=#1,markup=StrikeOut]{##1{$_\wedge$}}{##2}
            \else%
                {#2{\sout{##1}}}{#3{##2}}%
            \fi%
        \fi
        \if@showarrows% if in caption, draw end arrow
            \@ifundefined{@captype}{}{{#3{\Large$\bm{\Longleftarrow}$}}}\fi%
        }%
    % "\###Ins" for adding text
    \expandafter\newcommand\csname #1Ins\endcsname[1]{\PackageWarning{ezedits}{Unresolved modifications by #1: "##1" inserted.}%
        \if@showarrows%
            \@ifundefined{@captype}%
                {\marginnote{{#3{\Large$\bm{\Longleftarrow}$}}}}%
                {{#3{\Large$\bm{\Longrightarrow}$}}}%
        \fi%
        \if@accept % Display as if accepted
            { }##1%
        \else%
            \if@pdfcomm%
                % \pdfcomment[author=#1,icon=Insert]{##1}%
                \pdfmarkupcomment[author=#1,markup=Underline]{$_\wedge$}{##1}
            \else%
                {#3{##1}}%
            \fi%
        \fi
        \if@showarrows% if in caption, draw end arrow
            \@ifundefined{@captype}{}{{#3{\Large$\bm{\Longleftarrow}$}}}\fi%
        }%
    % "\###Del" for removing text
    \expandafter\newcommand\csname #1Del\endcsname[1]{\PackageWarning{ezedits}{Unresolved modifications by #1: "##1" removed.}%
        \if@showarrows%
            \@ifundefined{@captype}%
                {\marginnote{{#3{\Large$\bm{\Longleftarrow}$}}}}%
                {{#3{\Large$\bm{\Longrightarrow}$}}}%
        \fi%
        \if@accept % Display as if accepted
            {}%
        \else%
            \if@pdfcomm%
                \pdfmarkupcomment[author=#1,markup=StrikeOut,color=red]{##1}{}
            \else%
                {#2{\sout{##1}}}%
            \fi%
        \fi
        \if@showarrows% if in caption, draw end arrow
            \@ifundefined{@captype}{}{{#3{\Large$\bm{\Longleftarrow}$}}}\fi%
        }%
        
% "\###repl" for removing and adding text
    \expandafter\newcommand\csname#1repl\endcsname[2]{\PackageWarning{ezedits}{Unresolved modifications by #1: "##1" ---> "##2"}%
        \if@accept% Display as if accepted
            \if@showarrows%
                \@ifundefined{@captype}%
                    {\unskip\marginnote{{\textcolor{g}{\Large$\bm{\Longleftarrow}$}}}}%
                    {\unskip{\textcolor{g}{\Large$\bm{\Longrightarrow}$}}}%
                \fi%
            { }##2%
        \else%
            \if@showarrows%
                \@ifundefined{@captype}%
                    {\marginnote{{#3{\Large$\bm{\Longleftarrow}$}}}}%
                    {{#3{\Large$\bm{\Longrightarrow}$}}}%
            \fi%
            \if@pdfcomm%
                \pdfmarkupcomment[author=#1,markup=StrikeOut]{##1{$_\wedge$}}{##2}
            \else%
                \if@reject% display as if rejected
                    ##1%
                \else%
                    {#2{\sout{##1}}} {#3{##2}}%
                \fi
            \fi%
        \fi%
        \if@showarrows% if in caption, draw end arrow
            \@ifundefined{@captype}{}{{#3{\Large$\bm{\Longleftarrow}$}}}\fi%
        }%
    % "\###add" for adding text
    \expandafter\newcommand\csname#1add\endcsname[1]{\PackageWarning{ezedits}{Unresolved modifications by #1: "##1" inserted.}%
        \if@accept % Display as if accepted
            \if@showarrows%
                \@ifundefined{@captype}%
                    {\unskip\marginnote{{\textcolor{g}{\Large$\bm{\Longleftarrow}$}}}}%
                    {\unskip{\textcolor{g}{\Large$\bm{\Longrightarrow}$}}}%
            \fi%
            { }##1%
        \else%
            \if@showarrows%
                \@ifundefined{@captype}%
                    {\marginnote{{#3{\Large$\bm{\Longleftarrow}$}}}}%
                    {{#3{\Large$\bm{\Longrightarrow}$}}}%
            \fi%
            \if@pdfcomm%
                % \pdfcomment[author=#1,icon=Insert]{##1}%
                \pdfmarkupcomment[author=#1,markup=Underline]{$_\wedge$}{##1}
            \else%
                \if@reject%
                    \unskip%
                \else
                    {#3{##1}}%
                \fi
            \fi%
        \fi%
        \if@showarrows% if in caption, draw end arrow
            \@ifundefined{@captype}{}{{#3{\Large$\bm{\Longleftarrow}$}}}\fi%
        }%
    % "\###del" for removing text
    \expandafter\newcommand\csname#1del\endcsname[1]{\PackageWarning{ezedits}{Unresolved modifications by #1: "##1" removed.}%
        \if@accept% Display as if accepted
            \if@showarrows%
                \@ifundefined{@captype}%
                    {\unskip\marginnote{{\textcolor{g}{\Large$\bm{\Longleftarrow}$}}}}%
                    {\unskip{\textcolor{g}{\Large$\bm{\Longrightarrow}$}}}%
                \fi%        
            \unskip\unpenalty%
        \else%
            \if@showarrows%
                \@ifundefined{@captype}%
                    {\marginnote{{#3{\Large$\bm{\Longleftarrow}$}}}}%
                    {{#3{\Large$\bm{\Longrightarrow}$}}}%
            \fi%
            \if@pdfcomm%
                \pdfmarkupcomment[author=#1,markup=StrikeOut,color=red]{##1}{}
            \else%
                \if@reject%
                    ##1%
                \else%
                    {#2{\sout{##1}}}%
                \fi
            \fi%
        \fi%
        \if@showarrows% if in caption, draw end arrow
            \@ifundefined{@captype}{}{{#3{\Large$\bm{\Longleftarrow}$}}}\fi%
        }%
    % "\###note" for commenting
    \expandafter\newcommand\csname#1\endcsname[1]{\PackageWarning{ezedits}{Unresolved note by #1: "##1"}%
        \if@accept% Display as if accepted / resolved
            \if@showarrows%
                \@ifundefined{@captype}%
                    {\unskip\marginnote{{\textcolor{g}{\Large$\bm{\Longleftarrow}$}}}}%
                    {\unskip{\textcolor{g}{\Large$\bm{\Longrightarrow}$}}}%
            \fi%
            \unskip\unpenalty%
        \else%
            \if@showarrows%
                \@ifundefined{@captype}%
                    {\marginnote{{#3{\Large$\bm{\Longleftarrow}$}}}}%
                    {{#3{\Large$\bm{\Longrightarrow}$}}}%
            \fi%
            \if@pdfcomm%
                \pdfmarkupcomment[author=#1]{##1}
            \else%
                \if@reject%
                    {}%
                \else%
                    {#3{\texttt{[#1: ##1]}}}%
                \fi
            \fi%
        \fi%
        \if@showarrows% if in caption, draw end arrow
            \@ifundefined{@captype}{}{{#3{\Large$\bm{\Longleftarrow}$}}}\fi%
        }%
}

\endinput